# Codexa API server environment
#
# Copy this file to `.env` (kept out of git) and fill in the values.
# The server loads `.env` from the repo root automatically on start.

# --- Session signing ---
# Secret used to sign session tokens and OAuth state. Use a long random value.
CODEXA_AUTH_SECRET=change-me-to-a-long-random-string

# --- GitHub OAuth (sign in + repo pull + pull requests) ---
# Create an OAuth App at GitHub > Settings > Developer settings > OAuth Apps.
# Authorization callback URL must match CODEXA_GITHUB_CALLBACK_URL below.
CODEXA_GITHUB_CLIENT_ID=
CODEXA_GITHUB_CLIENT_SECRET=
CODEXA_GITHUB_CALLBACK_URL=http://localhost:4000/auth/github/callback
# `repo` is required to create branches and open pull requests.
CODEXA_GITHUB_SCOPES=repo read:user user:email

# --- Web origin ---
# Where the OAuth callback redirects back to (the Next.js app).
CODEXA_WEB_ORIGIN=http://localhost:3001

# --- Server ---
# Port the API listens on.
PORT=4000

# --- Persistence ---
# Directory for file-backed repositories when not using in-memory storage.
# CODEXA_DATA_DIR=./.codexa-data
